PORT=3000
NODE_ENV=development
# DB name is appended based on NODE_ENV: "dev" when not production, "prod" when NODE_ENV=production
MONGO_URI=mongodb://localhost:27017/

# Long random string. Tokens are signed with it; rotate to force all sessions to log out.
JWT_SECRET=
# Token lifetime as ms-style string (e.g. 7d, 12h)
JWT_EXPIRES_IN=7d

# Allowed users (only these two can log in)
USER_VIKA_PASSWORD=
USER_DANIL_PASSWORD=

# Cloudflare R2 (S3-compatible). Endpoint built from account id.
R2_ACCOUNT_ID=
R2_BUCKET=us-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
